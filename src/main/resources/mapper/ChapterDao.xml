<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="app.preach.gospel.dao.ChapterDao">

    <resultMap id="chapterResultMap" type="app.preach.gospel.model.Chapter">
        <constructor>
            <idArg column="ID"      javaType="Integer" />
            <arg   column="NAME"    javaType="String"  />
            <arg   column="NAME_JP" javaType="String"  />
            <arg   column="BOOK_ID" javaType="Integer" />
        </constructor>
    </resultMap>

    <!-- bookId指定、かつID昇順で章節を取得 -->
    <select id="selectByBookIdOrderByIdAsc" resultMap="chapterResultMap">
        SELECT CT.ID, CT.NAME, CT.NAME_JP, CT.BOOK_ID
        FROM CHAPTERS CT
        <where>
            <if test="bookId != null">
                CT.BOOK_ID = #{bookId}
            </if>
        </where>
        ORDER BY CT.ID ASC
    </select>

    <!-- IDで1件取得 -->
    <select id="selectById" resultMap="chapterResultMap">
        SELECT CT.ID, CT.NAME, CT.NAME_JP, CT.BOOK_ID
        FROM CHAPTERS CT
        <where>
            <if test="id != null">
                CT.ID = #{id}
            </if>
        </where>
    </select>

</mapper>
