<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="app.preach.gospel.dao.VerseDao">

	<resultMap id="verseResultMap"
		type="app.preach.gospel.model.Verse">
		<constructor>
			<idArg column="ID" javaType="Long" />
			<arg column="NAME" javaType="String" />
			<arg column="TEXT_EN" javaType="String" />
			<arg column="TEXT_JP" javaType="String" />
			<arg column="CHAPTER_ID" javaType="Integer" />
			<arg column="CHANGE_LINE" javaType="String" />
		</constructor>
	</resultMap>

	<!-- 全節を取得 -->
	<select id="selectAll" resultMap="verseResultMap">
		SELECT VA.ID, VA.NAME,
		VA.TEXT_EN, VA.TEXT_JP, VA.CHAPTER_ID, VA.CHANGE_LINE
		FROM VERSES VA
		ORDER BY VA.ID ASC
	</select>

	<!-- IDで1件取得 -->
	<select id="selectById" resultMap="verseResultMap">
		SELECT VA.ID, VA.NAME,
		VA.TEXT_EN, VA.TEXT_JP, VA.CHAPTER_ID, VA.CHANGE_LINE
		FROM VERSES VA
		WHERE VA.ID = #{id}
	</select>

	<!-- chapterId指定でID昇順に取得 -->
	<select id="selectByChapterIdOrderByIdAsc"
		resultMap="verseResultMap">
		SELECT VA.ID, VA.NAME, VA.TEXT_EN, VA.TEXT_JP,
		VA.CHAPTER_ID, VA.CHANGE_LINE
		FROM VERSES VA
		WHERE VA.CHAPTER_ID =
		#{chapterId}
		ORDER BY VA.ID ASC
	</select>

</mapper>
